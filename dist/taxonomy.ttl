@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dpv-ai: <https://w3id.org/dpv/ai#> .
@prefix eticas: <https://taxonomy.eticas.ai/risk/> .
@prefix eticas-ont: <https://taxonomy.eticas.ai/ontology/> .
@prefix eu-ai-act: <https://w3id.org/dpv/legal/eu/aiact#> .
@prefix iso-42001: <https://taxonomy.eticas.ai/external/iso-42001/> .
@prefix mit: <https://airisk.mit.edu/domain/> .
@prefix nist-600: <https://taxonomy.eticas.ai/external/nist-ai-600-1/> .
@prefix nist-rmf: <https://taxonomy.eticas.ai/external/nist-ai-rmf/> .
@prefix oecd: <https://taxonomy.eticas.ai/external/oecd-ai/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

mit:domain-1 skos:prefLabel "Discrimination & Toxicity"@en .

mit:domain-3 skos:prefLabel "Misinformation"@en .

mit:domain-4 skos:prefLabel "Malicious Actors & Misuse"@en .

mit:subdomain-1.2 skos:prefLabel "Exposure to toxic content"@en .

mit:subdomain-1.3 skos:prefLabel "Unequal performance across groups"@en .

mit:subdomain-2.1 skos:prefLabel "Compromise of privacy"@en .

mit:subdomain-2.2 skos:prefLabel "AI system security vulnerabilities & attacks"@en .

mit:subdomain-5.2 skos:prefLabel "Loss of human agency & autonomy"@en .

mit:subdomain-6.5 skos:prefLabel "Governance failure"@en .

mit:subdomain-6.6 skos:prefLabel "Environmental harm"@en .

mit:subdomain-7.3 skos:prefLabel "Lack of capability or robustness"@en .

mit:subdomain-7.4 skos:prefLabel "Lack of transparency or interpretability"@en .

mit:subdomain-7.6 skos:prefLabel "Multi-agent risks"@en .

iso-42001:A.10 skos:prefLabel "Third-party and customer relationships"@en .

iso-42001:A.2-A.4 skos:prefLabel "AI Policy, Internal Organisation, Resources"@en .

iso-42001:A.8 skos:prefLabel "Assessing impacts of AI systems"@en .

nist-600:dangerous-content skos:prefLabel "Dangerous, Violent, or Hateful Content"@en .

nist-600:data-privacy skos:prefLabel "Data Privacy"@en .

nist-600:environmental skos:prefLabel "Environmental Impacts"@en .

nist-600:harmful-bias skos:prefLabel "Harmful Bias & Homogenization"@en .

nist-600:human-ai-configuration skos:prefLabel "Human-AI Configuration"@en .

nist-600:information-integrity skos:prefLabel "Information Integrity"@en .

nist-600:information-security skos:prefLabel "Information Security"@en .

nist-600:value-chain skos:prefLabel "Value Chain & Component Integration"@en .

nist-rmf:explainable-interpretable skos:prefLabel "Explainable & Interpretable"@en .

nist-rmf:fair skos:prefLabel "Fair with Harmful Bias Managed"@en .

nist-rmf:map skos:prefLabel "MAP function — context and deployment environment"@en .

nist-rmf:privacy-enhanced skos:prefLabel "Privacy-Enhanced"@en .

nist-rmf:valid-reliable skos:prefLabel "Valid & Reliable"@en .

oecd:principle-1.1 skos:prefLabel "Inclusive growth, sustainable development & well-being"@en .

oecd:principle-1.3 skos:prefLabel "Transparency & explainability"@en .

eticas:absence-of-appeal a skos:Concept ;
    skos:broader eticas:responsibility-redress ;
    skos:definition "No accessible process for individuals to challenge or appeal AI-driven decisions that affect them."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Absence of appeal mechanisms"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "developing" ;
    eticas-ont:scope "ALL" .

eticas:accessibility-barriers a skos:Concept ;
    skos:broader eticas:bias-fairness ;
    skos:definition "System design that excludes or disadvantages people with disabilities, including inaccessible interfaces, outputs, or interaction modes."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Accessibility barriers"@en ;
    eticas-ont:lifecycleStage "post-processing",
        "pre-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "ALL" .

eticas:adversarial-attacks a skos:Concept ;
    skos:broader eticas:security-misuse ;
    skos:definition "Evasion, poisoning, and extraction attacks designed to manipulate system behaviour, corrupt training data, or steal model information."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Adversarial attacks"@en ;
    eticas-ont:lifecycleStage "in-processing",
        "post-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "ALL" .

eticas:agentic-risks a skos:Concept ;
    skos:closeMatch mit:subdomain-7.6 ;
    skos:definition "The risk that AI systems operating with a degree of autonomy — planning, executing multi-step actions, using tools, or coordinating with other AI agents — introduce failure modes not present in single-inference systems. This includes cascading errors across agent chains, unintended emergent behaviour, and loss of meaningful human control over compound actions."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Agentic Risks"@en ;
    skos:topConceptOf eticas:scheme ;
    eticas-ont:inclusion "audit-dependent" ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:perspective "technical soundness" ;
    eticas-ont:scope "LLM" .

eticas:ai-interaction-disclosure a skos:Concept ;
    dcterms:source "HRA" ;
    skos:broader eticas:transparency-explainability ;
    skos:definition "Users interacting with an AI system under the assumption that they are communicating with a human, without clear disclosure."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Disclosure of AI interaction"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:scope "LLM" .

eticas:allocation-of-opportunity a skos:Concept ;
    dcterms:source "HRA" ;
    skos:altLabel "Allocation of opportunity"@en ;
    skos:broader eticas:bias-fairness ;
    skos:definition "AI system outputs that lead to the uneven allocation of opportunities (e.g., jobs, credit, services) across demographic groups."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Unequal allocation of opportunity"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:scope "ADM" .

eticas:autonomy a skos:Concept ;
    skos:altLabel "Human Autonomy"@en ;
    skos:closeMatch mit:subdomain-5.2,
        nist-600:human-ai-configuration ;
    skos:definition "The risk that an AI system undermines individuals' ability to make free, informed decisions, whether through over-reliance, automation bias, manipulative design, or erosion of human agency."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Autonomy & Human Agency"@en ;
    skos:topConceptOf eticas:scheme ;
    eticas-ont:inclusion "audit-dependent" ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:perspective "rights & ethics" ;
    eticas-ont:scope "ALL" .

eticas:biometric-surveillance a skos:Concept ;
    skos:broader eticas:privacy-confidentiality ;
    skos:definition "Mass collection and processing of biometric data (face, voice, gait, fingerprints) for identification or tracking purposes."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Biometric surveillance"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "ADM" .

eticas:contextual-resilience a skos:Concept ;
    skos:broader eticas:resilience ;
    skos:definition "Absence of safeguards against function creep, weaponisation, or repurposing of the system against the populations it was designed to serve. Includes adequacy of consent mechanisms under power asymmetries and protection of beneficiary data in humanitarian or conflict contexts."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Contextual and ethical resilience"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "proposed" ;
    eticas-ont:scope "ALL" .

eticas:data-governance a skos:Concept ;
    dcterms:source "HRA" ;
    skos:broader eticas:governance ;
    skos:definition "Inadequate labelling, tagging, approval, or appropriateness assessment of data, leading to downstream issues with fitness for purpose, bias, and compliance."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Data governance"@en ;
    eticas-ont:lifecycleStage "pre-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:scope "ALL" .

eticas:dataset-bias a skos:Concept ;
    skos:broader eticas:bias-fairness ;
    skos:closeMatch mit:subdomain-1.1 ;
    skos:definition "Training or evaluation data that does not adequately represent all relevant population groups, leading to systematic performance differences or exclusion of certain groups."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Dataset bias and under/over-representation"@en ;
    eticas-ont:lifecycleStage "pre-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "ALL" .

eticas:decision-traceability a skos:Concept ;
    dcterms:source "HRA" ;
    skos:broader eticas:governance ;
    skos:definition "Inability to trace decisions made or influenced by the AI system back to specific inputs, processes, or actors, making it impossible to investigate harms or assign responsibility."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Decision traceability"@en ;
    eticas-ont:lifecycleStage "in-processing",
        "post-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:scope "ALL" .

eticas:deployment-sustainability a skos:Concept ;
    skos:broader eticas:integration-readiness ;
    skos:definition "The organisation lacks the capacity for ongoing operation, maintenance, monitoring, and improvement of the AI system after initial deployment. Includes vendor lock-in risk, dependency on external expertise, and unclear cost-effectiveness or value proposition."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Deployment sustainability"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "proposed" ;
    eticas-ont:scope "ALL" .

eticas:edge-offline-operability a skos:Concept ;
    skos:broader eticas:resilience ;
    skos:definition "System inability to function without continuous cloud access or network connectivity, creating single points of failure in environments with unreliable infrastructure."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Edge and offline operability"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "proposed" ;
    eticas-ont:scope "ALL" .

eticas:emotion-inference-profiling a skos:Concept ;
    skos:broader eticas:privacy-confidentiality ;
    skos:definition "Inference of emotional states, political opinions, sexual orientation, health status, or other sensitive attributes from behavioural or interaction data."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Emotion inference or sensitive attribute profiling"@en ;
    eticas-ont:lifecycleStage "in-processing",
        "post-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "ALL" .

eticas:failure-remediation-gaps a skos:Concept ;
    dcterms:source "HRA" ;
    skos:altLabel "Failures and remediations"@en ;
    skos:broader eticas:reliability ;
    skos:definition "Absence of remediation plans for predictable or unknown failure modes, leaving critical services unable to recover or degrade gracefully."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Failure and remediation gaps"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:scope "ALL" .

eticas:feedback-loops a skos:Concept ;
    skos:broader eticas:bias-fairness ;
    skos:definition "System outputs that, when fed back into the system or its operational context, amplify existing biases over time."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Feedback loops reinforcing inequality"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "ALL" .

eticas:fitness-for-purpose a skos:Concept ;
    dcterms:source "HRA" ;
    skos:broader eticas:governance ;
    skos:definition "System not validated against the problem it is intended to solve, leading to incorrect outputs or failure to deliver expected results."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Fitness for purpose"@en ;
    eticas-ont:lifecycleStage "in-processing",
        "pre-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:scope "ALL" .

eticas:function-creep a skos:Concept ;
    skos:broader eticas:privacy-confidentiality ;
    skos:definition "Repurposing of personal data beyond the original intent or consent scope, including secondary uses not anticipated at collection time."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Function creep"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "ALL" .

eticas:geographic-cultural-language-skew a skos:Concept ;
    skos:broader eticas:bias-fairness ;
    skos:definition "Systematic performance differences across geographies, cultures, or languages, often resulting from training data that overrepresents certain regions or linguistic traditions."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Geographic, cultural, or language skew"@en ;
    eticas-ont:lifecycleStage "in-processing",
        "post-processing",
        "pre-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "ALL" .

eticas:graceful-degradation a skos:Concept ;
    skos:broader eticas:resilience ;
    skos:definition "Absence of defined degradation pathways that allow the system to maintain partial function when components fail, connectivity is lost, or resources are constrained."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Graceful degradation"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "proposed" ;
    eticas-ont:scope "ALL" .

eticas:hallucination a skos:Concept ;
    dcterms:source "HRA" ;
    skos:altLabel "Confabulation"@en,
        "Hallucination prevention"@en ;
    skos:broader eticas:reliability ;
    skos:definition "Generation of false, fabricated, or misleading information that appears credible, including invented facts, statistics, citations, or events."@en ;
    skos:exactMatch nist-600:confabulation ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Hallucination and fabricated outputs"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "LLM" .

eticas:hardware-efficiency a skos:Concept ;
    dcterms:source "HRA" ;
    skos:broader eticas:environmental-impact ;
    skos:definition "Poor hardware utilisation increasing costs, environmental footprint, and limiting the feasibility of equitable access to AI capabilities."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Hardware efficiency"@en ;
    eticas-ont:lifecycleStage "in-processing",
        "post-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:scope "ALL" .

eticas:harmful-content-toxicity a skos:Concept ;
    dcterms:source "HRA" ;
    skos:altLabel "Harmful content prevention"@en,
        "Toxicity"@en ;
    skos:broader eticas:bias-fairness ;
    skos:closeMatch mit:subdomain-1.2,
        nist-600:dangerous-content ;
    skos:definition "Offensive, hateful, or otherwise harmful outputs that damage user well-being and erode trust."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Harmful content and toxicity"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "developing" ;
    eticas-ont:scope "LLM" .

eticas:human-oversight-control a skos:Concept ;
    dcterms:source "HRA" ;
    skos:broader eticas:governance ;
    skos:definition "Lack of defined intervention points, override capabilities, or human review mechanisms, allowing issues and threats to persist unchecked."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Human oversight and control"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:scope "ALL" .

eticas:incident-response-gaps a skos:Concept ;
    skos:broader eticas:security-misuse ;
    skos:definition "Insufficient detection, logging, escalation, or response capabilities for security incidents and misuse events."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Incident response gaps"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "ALL" .

eticas:ineffective-communication a skos:Concept ;
    skos:broader eticas:responsibility-redress ;
    skos:definition "Failure to inform individuals about how they have been affected by AI-driven decisions and what options are available to them."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Ineffective communication with affected parties"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "developing" ;
    eticas-ont:scope "ALL" .

eticas:inference-energy-consumption a skos:Concept ;
    dcterms:source "HRA" ;
    skos:broader eticas:environmental-impact ;
    skos:definition "High energy use during deployment and inference, increasing environmental impact and infrastructure costs."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Inference-time energy consumption"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:scope "ALL" .

eticas:infrastructure-dependency a skos:Concept ;
    skos:broader eticas:resilience ;
    skos:definition "Unmapped or unmitigated dependencies on external infrastructure (power, connectivity, cloud services, third-party APIs) whose failure would disable the system."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Infrastructure dependency"@en ;
    eticas-ont:lifecycleStage "post-processing",
        "pre-processing" ;
    eticas-ont:maturity "proposed" ;
    eticas-ont:scope "ALL" .

eticas:input-output-logging a skos:Concept ;
    dcterms:source "HRA" ;
    skos:broader eticas:governance ;
    skos:definition "Failure to log inputs and outputs systematically, hindering detection of failures, bias, or misuse. For LLMs, unlogged prompts may prevent tracking of harmful or sensitive interactions."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Critical input/output logging"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:scope "ALL" .

eticas:institutional-capacity a skos:Concept ;
    skos:broader eticas:integration-readiness ;
    skos:definition "The broader institutional or societal context lacks foundational capabilities (digital infrastructure, data literacy, regulatory frameworks) needed before AI deployment is viable. Premature deployment may reallocate scarce resources, exacerbate inequality, or create technological dependency."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Institutional absorptive capacity"@en ;
    eticas-ont:lifecycleStage "pre-processing" ;
    eticas-ont:maturity "proposed" ;
    eticas-ont:scope "ALL" .

eticas:intersectional-unfairness a skos:Concept ;
    skos:broader eticas:bias-fairness ;
    skos:definition "Compounded disadvantage affecting individuals at the intersection of multiple protected characteristics (e.g., gender and ethnicity together producing worse outcomes than either alone)."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Intersectional unfairness"@en ;
    eticas-ont:lifecycleStage "in-processing",
        "post-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "ALL" .

eticas:jailbreaking a skos:Concept ;
    dcterms:source "HRA" ;
    skos:altLabel "Jailbreakability"@en ;
    skos:broader eticas:security-misuse ;
    skos:definition "Techniques used to bypass safety controls, content filters, or usage restrictions to trigger prohibited behaviours or outputs."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Jailbreaking"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "LLM" .

eticas:lack-of-change-management a skos:Concept ;
    skos:broader eticas:governance ;
    skos:definition "Absence of controlled processes for system modifications, including uncontrolled changes to production systems."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Lack of change management"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "ALL" .

eticas:limited-auditability a skos:Concept ;
    skos:broader eticas:governance ;
    skos:definition "Insufficient logging, versioning, or traceability for meaningful external review or internal audit."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Limited auditability"@en ;
    eticas-ont:lifecycleStage "in-processing",
        "post-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "ALL" .

eticas:manipulation-misinformation a skos:Concept ;
    skos:closeMatch mit:domain-3,
        nist-600:information-integrity ;
    skos:definition "The risk that AI systems are used — intentionally or through design flaws — to deceive, manipulate, or mislead individuals or populations. This includes generation of disinformation at scale, deepfakes, subliminal manipulation, and pollution of the information ecosystem."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Manipulation & Misinformation"@en ;
    skos:topConceptOf eticas:scheme ;
    eticas-ont:inclusion "audit-dependent" ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:perspective "rights & ethics" ;
    eticas-ont:scope "ALL" .

eticas:membership-inference a skos:Concept ;
    dcterms:source "HRA" ;
    skos:broader eticas:privacy-confidentiality ;
    skos:definition "The ability to determine whether specific individuals' data was included in the training set, compromising privacy and potentially violating data protection requirements."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Membership inference risk"@en ;
    eticas-ont:lifecycleStage "in-processing",
        "post-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:scope "LLM" .

eticas:misuse-beyond-intended-purpose a skos:Concept ;
    skos:broader eticas:security-misuse ;
    skos:definition "Use of the system for purposes it was not designed for, including repurposing for surveillance, manipulation, or other harmful applications."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Misuse beyond intended purpose"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "developing" ;
    eticas-ont:scope "ALL" .

eticas:model-card-completeness a skos:Concept ;
    dcterms:source "HRA" ;
    skos:broader eticas:transparency-explainability ;
    skos:definition "Incomplete or outdated documentation of model purpose, performance, limitations, or data sources, leading to inappropriate deployment or overestimation of capabilities."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Model card completeness"@en ;
    eticas-ont:lifecycleStage "post-processing",
        "pre-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:scope "ALL" .

eticas:monitoring-evaluation-gaps a skos:Concept ;
    dcterms:source "HRA" ;
    skos:altLabel "Monitoring, feedback, evaluation"@en ;
    skos:broader eticas:reliability ;
    skos:definition "Lack of ongoing monitoring that renders datasets obsolete and system outputs unreliable, including absence of feedback mechanisms and periodic evaluation."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Monitoring and evaluation gaps"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:scope "ALL" .

eticas:organisational-readiness a skos:Concept ;
    skos:broader eticas:integration-readiness ;
    skos:definition "The deploying organisation lacks the governance maturity, leadership engagement, change management capacity, staff competency, or cultural receptivity needed to absorb an AI system into its operations."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Organisational readiness"@en ;
    eticas-ont:lifecycleStage "pre-processing" ;
    eticas-ont:maturity "proposed" ;
    eticas-ont:scope "ALL" .

eticas:out-of-distribution-robustness a skos:Concept ;
    dcterms:source "HRA" ;
    skos:broader eticas:reliability ;
    skos:definition "Unpredictable behaviour or failure when the system is exposed to inputs outside the distribution of its training data."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Out-of-distribution robustness"@en ;
    eticas-ont:lifecycleStage "in-processing",
        "post-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:scope "ALL" .

eticas:output-drift a skos:Concept ;
    skos:broader eticas:reliability ;
    skos:definition "Degradation of output quality or accuracy as data distributions, user behaviour, or operating conditions change after deployment."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Output drift over time"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "ALL" .

eticas:output-inconsistency a skos:Concept ;
    skos:broader eticas:reliability ;
    skos:definition "Inconsistent results across similar inputs and contexts, undermining reproducibility and user trust."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Output inconsistency"@en ;
    eticas-ont:lifecycleStage "in-processing",
        "post-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "ALL" .

eticas:oversight-of-adverse-impacts a skos:Concept ;
    dcterms:source "HRA" ;
    skos:broader eticas:governance ;
    skos:definition "Missing processes for identifying, escalating, and responding to harmful outcomes, including psychological or physical harm and threats to human life."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Oversight of significant adverse impacts"@en ;
    eticas-ont:lifecycleStage "post-processing",
        "pre-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:scope "ALL" .

eticas:performance-equity a skos:Concept ;
    dcterms:source "HRA" ;
    skos:altLabel "Group-wise error rate"@en ;
    skos:broader eticas:bias-fairness ;
    skos:closeMatch mit:subdomain-1.3 ;
    skos:definition "Higher error rates or lower accuracy for specific demographic groups, resulting in unfair or unequal service delivery."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Performance equity across populations"@en ;
    eticas-ont:lifecycleStage "in-processing",
        "post-processing" ;
    eticas-ont:maturity "developing" ;
    eticas-ont:scope "ALL" .

eticas:pii-leakage a skos:Concept ;
    dcterms:source "HRA" ;
    skos:altLabel "PII leakage rate"@en,
        "Privacy leakage"@en ;
    skos:broader eticas:privacy-confidentiality ;
    skos:definition "Personal data present in training data surfacing in model outputs, either through memorisation or through responses that reveal sensitive information about individuals."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "PII leakage through model outputs"@en ;
    eticas-ont:lifecycleStage "in-processing",
        "post-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "LLM" .

eticas:poor-documentation a skos:Concept ;
    skos:broader eticas:governance ;
    skos:definition "Incomplete, outdated, or absent documentation of system purpose, architecture, data sources, known limitations, and operational procedures."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Poor documentation"@en ;
    eticas-ont:lifecycleStage "in-processing",
        "post-processing",
        "pre-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "ALL" .

eticas:prompt-injection a skos:Concept ;
    dcterms:source "HRA" ;
    skos:altLabel "Prompt injection protection"@en ;
    skos:broader eticas:security-misuse ;
    skos:definition "Malicious inputs designed to subvert system intent by injecting instructions that override the system prompt, leading to harmful, deceptive, or unauthorized outputs."@en ;
    skos:exactMatch dpv-ai:PromptInjection ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Prompt injection"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "LLM" .

eticas:prompt-transparency a skos:Concept ;
    dcterms:source "HRA" ;
    skos:broader eticas:transparency-explainability ;
    skos:definition "Inconsistent outputs to semantically similar inputs that confuse users and erode trust. For LLMs, variation across generations may lead to contradictory advice or conflicting factual claims."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Prompt transparency"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:scope "LLM" .

eticas:proxy-discrimination a skos:Concept ;
    skos:broader eticas:bias-fairness ;
    skos:definition "Discrimination through features that correlate with protected attributes (e.g., postcode as proxy for ethnicity), even when protected attributes are not directly used."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Proxy discrimination through correlated features"@en ;
    eticas-ont:lifecycleStage "in-processing",
        "post-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "ALL" .

eticas:quality-of-service-disparity a skos:Concept ;
    dcterms:source "HRA" ;
    skos:altLabel "Quality of service"@en ;
    skos:broader eticas:bias-fairness ;
    skos:definition "Inconsistent service quality across demographic groups, leading to systematically better performance for some groups over others."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Quality of service disparity across groups"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:scope "ALL" .

eticas:re-identification a skos:Concept ;
    skos:broader eticas:privacy-confidentiality ;
    skos:definition "The possibility that anonymised or pseudonymised data can be linked back to specific individuals through inference, combination with other datasets, or model outputs."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Re-identification of anonymised data"@en ;
    eticas-ont:lifecycleStage "post-processing",
        "pre-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "ALL" .

eticas:recovery-capability a skos:Concept ;
    skos:broader eticas:resilience ;
    skos:definition "Lack of tested recovery procedures, rollback mechanisms, or recovery time objectives for restoring system function after disruption."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Recovery capability"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "proposed" ;
    eticas-ont:scope "ALL" .

eticas:regulatory-non-compliance a skos:Concept ;
    skos:broader eticas:governance ;
    skos:definition "Failure to align with applicable legal, ethical, or organisational standards, including sector-specific regulations."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Regulatory non-compliance"@en ;
    eticas-ont:lifecycleStage "post-processing",
        "pre-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "ALL" .

eticas:responsible-actor-attribution a skos:Concept ;
    dcterms:source "HRA" ;
    skos:broader eticas:governance ;
    skos:definition "Unclear or undocumented roles of developers, deployers, or reviewers, creating accountability gaps that can delay incident response or allow harmful practices to persist."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Responsible actor attribution"@en ;
    eticas-ont:lifecycleStage "post-processing",
        "pre-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:scope "ALL" .

eticas:sentiment-fairness a skos:Concept ;
    dcterms:source "HRA" ;
    skos:broader eticas:bias-fairness ;
    skos:definition "Unequal emotional tone in system outputs across demographic groups, leading to perceived or actual bias in how people are treated or described."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Sentiment fairness across groups"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "developing" ;
    eticas-ont:scope "LLM" .

eticas:stakeholder-communication a skos:Concept ;
    dcterms:source "HRA" ;
    skos:altLabel "Communication to relevant interested parties"@en ;
    skos:broader eticas:transparency-explainability ;
    skos:definition "Stakeholders not being made aware of AI system limitations, parameters, and settings that affect responsible use."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Communication to stakeholders"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:scope "ALL" .

eticas:stereotyping-demeaning-content a skos:Concept ;
    dcterms:source "HRA" ;
    skos:altLabel "Minimization of stereotyping"@en ;
    skos:broader eticas:bias-fairness ;
    skos:closeMatch mit:subdomain-1.1 ;
    skos:definition "AI system outputs that reinforce, perpetuate, erase, or demean demographic groups through stereotypical representations or language."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Stereotyping and demeaning content"@en ;
    eticas-ont:lifecycleStage "in-processing",
        "post-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:scope "ALL" .

eticas:supply-chain-vulnerabilities a skos:Concept ;
    skos:broader eticas:security-misuse ;
    skos:definition "Risks introduced through third-party components, pre-trained models, data sources, or other dependencies not fully under the deployer's control."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Supply-chain vulnerabilities"@en ;
    eticas-ont:lifecycleStage "in-processing",
        "pre-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "ALL" .

eticas:system-explainability a skos:Concept ;
    dcterms:source "HRA" ;
    skos:broader eticas:transparency-explainability ;
    skos:definition "Stakeholders misinterpret or misunderstand the intended purpose or use of an AI system based on its outputs, due to insufficient explanation of how outputs are produced."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "AI system explainability"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:scope "ALL" .

eticas:task-success a skos:Concept ;
    dcterms:source "HRA" ;
    skos:broader eticas:governance ;
    skos:definition "Low or uneven task success rates, particularly across subpopulations or input types, leading to systematic exclusion, service denial, or misinformation."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Task success"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:scope "ALL" .

eticas:technical-interoperability a skos:Concept ;
    skos:broader eticas:integration-readiness ;
    skos:definition "The AI system cannot integrate with existing infrastructure, legacy systems, data pipelines, or standards (e.g., HL7 FHIR in healthcare) required for it to function in the deployment environment."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Technical interoperability"@en ;
    eticas-ont:lifecycleStage "post-processing",
        "pre-processing" ;
    eticas-ont:maturity "proposed" ;
    eticas-ont:scope "ALL" .

eticas:training-resource-consumption a skos:Concept ;
    dcterms:source "HRA" ;
    skos:broader eticas:environmental-impact ;
    skos:definition "Significant carbon emissions, energy use, and water consumption associated with model training, particularly for large-scale foundation models."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Training resource consumption"@en ;
    eticas-ont:lifecycleStage "in-processing" ;
    eticas-ont:maturity "provisional" ;
    eticas-ont:scope "ALL" .

eticas:unauthorized-access a skos:Concept ;
    skos:broader eticas:security-misuse ;
    skos:definition "Exploitation of access control weaknesses to gain unauthorized access to the system, its data, or its administrative functions."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Unauthorized access"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "ALL" .

eticas:unclear-remediation a skos:Concept ;
    skos:broader eticas:responsibility-redress ;
    skos:definition "Absence of defined processes for correcting harms caused by AI system errors or failures."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Unclear remediation procedures"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "developing" ;
    eticas-ont:scope "ALL" .

eticas:unclear-responsibilities a skos:Concept ;
    skos:broader eticas:governance ;
    skos:definition "Missing or ambiguous assignment of roles and responsibilities for AI system design, deployment, monitoring, and incident response."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Unclear responsibilities and accountability gaps"@en ;
    eticas-ont:lifecycleStage "post-processing",
        "pre-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "ALL" .

eticas:unlawful-data-processing a skos:Concept ;
    skos:broader eticas:privacy-confidentiality ;
    skos:definition "Collection, storage, or processing of personal data without adequate legal basis, consent, or compliance with applicable data protection regulations."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Unlawful collection or processing of personal data"@en ;
    eticas-ont:lifecycleStage "pre-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "ALL" .

eticas:weak-data-controls a skos:Concept ;
    skos:broader eticas:privacy-confidentiality ;
    skos:definition "Insufficient policies or technical measures for data retention limits, secure deletion, and access restrictions, increasing the risk of unauthorized access or indefinite data persistence."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Weak data retention, erasure, and access controls"@en ;
    eticas-ont:lifecycleStage "post-processing",
        "pre-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:scope "ALL" .

eticas:workflow-compatibility a skos:Concept ;
    skos:broader eticas:integration-readiness ;
    skos:definition "The system's outputs, alerts, or interfaces do not fit existing human workflows, leading to alert fatigue, workarounds, or abandonment. Includes inadequate end-user involvement in design and testing, and poor context transferability from development to deployment environment."@en ;
    skos:inScheme eticas:scheme ;
    skos:prefLabel "Workflow compatibility"@en ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "proposed" ;
    eticas-ont:scope "ALL" .

dpv-ai:AIBias skos:prefLabel "AI Bias"@en .

dpv-ai:PersonalDataHandling skos:prefLabel "Personal Data Handling"@en .

dpv-ai:PromptInjection skos:prefLabel "Prompt Injection"@en .

dpv-ai:SecurityAttack skos:prefLabel "Security Attack"@en .

dpv-ai:Transparency skos:prefLabel "Transparency"@en .

eu-ai-act:article-15-4 skos:prefLabel "Article 15(4) — Resilience regarding errors, faults or inconsistencies"@en .

mit:subdomain-1.1 skos:prefLabel "Unfair discrimination & misrepresentation"@en .

nist-600:confabulation skos:prefLabel "Confabulation"@en .

nist-rmf:accountable-transparent skos:prefLabel "Accountable & Transparent"@en .

nist-rmf:secure-resilient skos:prefLabel "Secure & Resilient"@en .

oecd:principle-1.2 skos:prefLabel "Human rights, rule of law, fairness & privacy"@en .

oecd:principle-1.4 skos:prefLabel "Robustness, security & safety"@en .

oecd:principle-1.5 skos:prefLabel "Accountability"@en .

eticas:environmental-impact a skos:Concept ;
    skos:altLabel "Environmental sustainability"@en,
        "Sustainability"@en ;
    skos:broadMatch oecd:principle-1.1 ;
    skos:closeMatch mit:subdomain-6.6,
        nist-600:environmental ;
    skos:definition "The risk that an AI system's development, deployment, or use causes negative environmental effects, such as excessive energy or water consumption, carbon emissions, or unsustainable use of hardware and resources. This includes hidden impacts across the system's lifecycle, from model training to long-term operation."@en ;
    skos:inScheme eticas:scheme ;
    skos:narrower eticas:hardware-efficiency,
        eticas:inference-energy-consumption,
        eticas:training-resource-consumption ;
    skos:prefLabel "Environmental Impact"@en ;
    skos:topConceptOf eticas:scheme ;
    eticas-ont:inclusion "audit-dependent" ;
    eticas-ont:lifecycleStage "in-processing",
        "post-processing",
        "pre-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:perspective "technical soundness" ;
    eticas-ont:scope "ALL" .

eticas:responsibility-redress a skos:Concept ;
    skos:broadMatch nist-rmf:accountable-transparent,
        oecd:principle-1.5 ;
    skos:definition "The risk that individuals affected by AI-driven decisions have no effective means to understand, challenge, or seek remedy for those decisions. This includes absence of appeal mechanisms, unclear remediation procedures, and failure to communicate with affected parties."@en ;
    skos:inScheme eticas:scheme ;
    skos:narrower eticas:absence-of-appeal,
        eticas:ineffective-communication,
        eticas:unclear-remediation ;
    skos:note "In the RAIA Guide, this category is assessed only at the Post-Processing stage."@en ;
    skos:prefLabel "Responsibility & Redress"@en ;
    skos:topConceptOf eticas:scheme ;
    eticas-ont:inclusion "audit-dependent" ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "developing" ;
    eticas-ont:perspective "rights & ethics" ;
    eticas-ont:scope "ALL" .

eticas:integration-readiness a skos:Concept ;
    skos:altLabel "Deployment readiness"@en,
        "Operational risk"@en,
        "Sociotechnical fit"@en ;
    skos:definition "The risk that an AI system fails to deliver value not because of model performance issues but because it does not fit the organisational, technical, or human context into which it is deployed. This includes interoperability failures with existing systems, insufficient organisational capacity to absorb the technology, workflow incompatibility, and lack of sustainable maintenance capability. Between 70 and 85% of AI initiatives fail to meet their objectives, primarily due to these integration factors rather than model quality."@en ;
    skos:inScheme eticas:scheme ;
    skos:narrower eticas:deployment-sustainability,
        eticas:institutional-capacity,
        eticas:organisational-readiness,
        eticas:technical-interoperability,
        eticas:workflow-compatibility ;
    skos:prefLabel "Integration Readiness"@en ;
    skos:relatedMatch iso-42001:A.10,
        nist-rmf:map ;
    skos:topConceptOf eticas:scheme ;
    eticas-ont:inclusion "audit-dependent" ;
    eticas-ont:lifecycleStage "post-processing",
        "pre-processing" ;
    eticas-ont:maturity "proposed" ;
    eticas-ont:perspective "operational viability" ;
    eticas-ont:scope "ALL" .

eticas:resilience a skos:Concept ;
    skos:altLabel "Operational resilience"@en,
        "System resilience"@en ;
    skos:broadMatch nist-rmf:secure-resilient,
        eu-ai-act:article-15-4 ;
    skos:definition "The risk that an AI system cannot absorb disruption, degrade gracefully, or recover when faced with adverse events, attacks, infrastructure failures, or environmental changes. This goes beyond reliability (consistent performance under normal conditions) and robustness (performance under varied conditions) to address what happens when the system is genuinely disrupted and must recover or continue operating in degraded mode. Particularly critical for AI deployed in conflict zones, humanitarian operations, or critical infrastructure."@en ;
    skos:inScheme eticas:scheme ;
    skos:narrower eticas:contextual-resilience,
        eticas:edge-offline-operability,
        eticas:graceful-degradation,
        eticas:infrastructure-dependency,
        eticas:recovery-capability ;
    skos:prefLabel "Resilience"@en ;
    skos:topConceptOf eticas:scheme ;
    eticas-ont:inclusion "audit-dependent" ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "proposed" ;
    eticas-ont:perspective "operational viability" ;
    eticas-ont:scope "ALL" .

eticas:transparency-explainability a skos:Concept ;
    skos:altLabel "Explainability & Transparency"@en,
        "Transparency and Explainability"@en ;
    skos:broadMatch dpv-ai:Transparency ;
    skos:closeMatch mit:subdomain-7.4,
        nist-rmf:explainable-interpretable,
        oecd:principle-1.3 ;
    skos:definition "The risk that stakeholders cannot understand how an AI system works, what it does, or why it produces specific outputs. Lack of transparency undermines informed consent, impedes oversight, and erodes trust."@en ;
    skos:inScheme eticas:scheme ;
    skos:narrower eticas:ai-interaction-disclosure,
        eticas:model-card-completeness,
        eticas:prompt-transparency,
        eticas:stakeholder-communication,
        eticas:system-explainability ;
    skos:note "In the RAIA Guide, this category is assessed only at the Post-Processing stage."@en ;
    skos:prefLabel "Transparency & Explainability"@en ;
    skos:topConceptOf eticas:scheme ;
    eticas-ont:inclusion "required" ;
    eticas-ont:lifecycleStage "post-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:perspective "governance & compliance" ;
    eticas-ont:scope "ALL" .

eticas:reliability a skos:Concept ;
    skos:altLabel "Reliability & Manipulation"@en,
        "Validity and Reliability"@en ;
    skos:broadMatch oecd:principle-1.4 ;
    skos:closeMatch mit:subdomain-7.3,
        nist-600:confabulation,
        nist-rmf:valid-reliable ;
    skos:definition "The risk that an AI system produces false, fabricated, or misleading outputs (hallucinations), spreads inaccurate or deceptive information (misinformation), or delivers inconsistent results across similar inputs and contexts. Such failures undermine trust, reduce system dependability, and can lead to harmful or misguided decisions."@en ;
    skos:inScheme eticas:scheme ;
    skos:narrower eticas:failure-remediation-gaps,
        eticas:hallucination,
        eticas:monitoring-evaluation-gaps,
        eticas:out-of-distribution-robustness,
        eticas:output-drift,
        eticas:output-inconsistency ;
    skos:prefLabel "Reliability"@en ;
    skos:topConceptOf eticas:scheme ;
    eticas-ont:inclusion "required" ;
    eticas-ont:lifecycleStage "in-processing",
        "post-processing",
        "pre-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:perspective "technical soundness" ;
    eticas-ont:scope "ALL" .

eticas:security-misuse a skos:Concept ;
    skos:altLabel "Safety"@en,
        "Safety, Security & Misuse"@en,
        "Security"@en ;
    skos:broadMatch oecd:principle-1.4,
        dpv-ai:SecurityAttack ;
    skos:closeMatch mit:domain-4,
        mit:subdomain-2.2,
        nist-600:information-security,
        nist-rmf:secure-resilient ;
    skos:definition "The risk that an AI system is exposed to vulnerabilities, attacks, or misuse that compromise its integrity, availability, or confidentiality. This includes adversarial inputs, model inversion, data poisoning, prompt injection, and unauthorized access, which can lead to manipulation of outputs, data breaches, or system failure."@en ;
    skos:inScheme eticas:scheme ;
    skos:narrower eticas:adversarial-attacks,
        eticas:incident-response-gaps,
        eticas:jailbreaking,
        eticas:misuse-beyond-intended-purpose,
        eticas:prompt-injection,
        eticas:supply-chain-vulnerabilities,
        eticas:unauthorized-access ;
    skos:prefLabel "Security & Misuse"@en ;
    skos:topConceptOf eticas:scheme ;
    eticas-ont:inclusion "required" ;
    eticas-ont:lifecycleStage "in-processing",
        "post-processing",
        "pre-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:perspective "technical soundness" ;
    eticas-ont:scope "ALL" .

eticas:privacy-confidentiality a skos:Concept ;
    skos:altLabel "Data Privacy"@en,
        "Privacy"@en ;
    skos:broadMatch oecd:principle-1.2,
        dpv-ai:PersonalDataHandling ;
    skos:closeMatch mit:subdomain-2.1,
        nist-600:data-privacy,
        nist-rmf:privacy-enhanced ;
    skos:definition "The risk that an AI system collects, processes, or infers personal information in ways that infringe on individuals' rights to control their data (privacy), or that sensitive information is exposed, accessed, or shared without authorization (confidentiality). This includes risks from data leakage, re-identification, unauthorized use, or insufficient safeguards."@en ;
    skos:inScheme eticas:scheme ;
    skos:narrower eticas:biometric-surveillance,
        eticas:emotion-inference-profiling,
        eticas:function-creep,
        eticas:membership-inference,
        eticas:pii-leakage,
        eticas:re-identification,
        eticas:unlawful-data-processing,
        eticas:weak-data-controls ;
    skos:prefLabel "Privacy & Confidentiality"@en ;
    skos:topConceptOf eticas:scheme ;
    eticas-ont:inclusion "required" ;
    eticas-ont:lifecycleStage "in-processing",
        "post-processing",
        "pre-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:perspective "rights & ethics" ;
    eticas-ont:scope "ALL" .

eticas:bias-fairness a skos:Concept ;
    skos:altLabel "Algorithmic fairness"@en,
        "Bias & Discrimination"@en,
        "Fairness"@en ;
    skos:broadMatch oecd:principle-1.2,
        dpv-ai:AIBias ;
    skos:closeMatch mit:domain-1,
        nist-600:harmful-bias,
        nist-rmf:fair ;
    skos:definition "The risk that an AI system produces outcomes that systematically advantage or disadvantage individuals or groups based on protected or sensitive attributes, leading to unequal treatment, reduced accuracy, or unjust impacts. This includes biases introduced through data, model design, or deployment context, and covers both measurable disparities and perceived unfairness in decision-making."@en ;
    skos:inScheme eticas:scheme ;
    skos:narrower eticas:accessibility-barriers,
        eticas:allocation-of-opportunity,
        eticas:dataset-bias,
        eticas:feedback-loops,
        eticas:geographic-cultural-language-skew,
        eticas:harmful-content-toxicity,
        eticas:intersectional-unfairness,
        eticas:performance-equity,
        eticas:proxy-discrimination,
        eticas:quality-of-service-disparity,
        eticas:sentiment-fairness,
        eticas:stereotyping-demeaning-content ;
    skos:prefLabel "Bias & Fairness"@en ;
    skos:relatedMatch iso-42001:A.8 ;
    skos:topConceptOf eticas:scheme ;
    eticas-ont:inclusion "required" ;
    eticas-ont:lifecycleStage "in-processing",
        "post-processing",
        "pre-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:perspective "rights & ethics" ;
    eticas-ont:scope "ALL" .

eticas:governance a skos:Concept ;
    skos:altLabel "Accountability"@en,
        "Governance & Accountability"@en ;
    skos:broadMatch iso-42001:A.2-A.4 ;
    skos:closeMatch mit:subdomain-6.5,
        nist-rmf:accountable-transparent,
        oecd:principle-1.5 ;
    skos:definition "The risk that an AI system lacks adequate structures, policies, or accountability mechanisms to oversee its design, deployment, and use. Weak governance can lead to unclear responsibilities, poor documentation, limited auditability, and failure to align with legal, ethical, or organizational standards."@en ;
    skos:inScheme eticas:scheme ;
    skos:narrower eticas:data-governance,
        eticas:decision-traceability,
        eticas:fitness-for-purpose,
        eticas:human-oversight-control,
        eticas:input-output-logging,
        eticas:lack-of-change-management,
        eticas:limited-auditability,
        eticas:oversight-of-adverse-impacts,
        eticas:poor-documentation,
        eticas:regulatory-non-compliance,
        eticas:responsible-actor-attribution,
        eticas:task-success,
        eticas:unclear-responsibilities ;
    skos:prefLabel "Governance"@en ;
    skos:relatedMatch nist-600:value-chain ;
    skos:topConceptOf eticas:scheme ;
    eticas-ont:inclusion "required" ;
    eticas-ont:lifecycleStage "in-processing",
        "post-processing",
        "pre-processing" ;
    eticas-ont:maturity "established" ;
    eticas-ont:perspective "governance & compliance" ;
    eticas-ont:scope "ALL" .

eticas:scheme a skos:ConceptScheme ;
    dcterms:description "A unified AI risk taxonomy for use across Eticas audit methodologies, assessment frameworks, and reporting outputs."@en ;
    dcterms:language "en" ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:publisher "Eticas" ;
    skos:hasTopConcept eticas:agentic-risks,
        eticas:autonomy,
        eticas:bias-fairness,
        eticas:environmental-impact,
        eticas:governance,
        eticas:integration-readiness,
        eticas:manipulation-misinformation,
        eticas:privacy-confidentiality,
        eticas:reliability,
        eticas:resilience,
        eticas:responsibility-redress,
        eticas:security-misuse,
        eticas:transparency-explainability ;
    skos:prefLabel "Eticas AI Risk Taxonomy"@en .

