        "@language": "en",
        "@value": "Safety"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broadMatch": [
      {
        "@id": "https://taxonomy.eticas.ai/external/oecd-ai/principle-1.4"
      },
      {
        "@id": "https://w3id.org/dpv/ai#SecurityAttack"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
