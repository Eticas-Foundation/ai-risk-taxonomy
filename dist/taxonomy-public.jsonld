        "@id": "https://airisk.mit.edu/domain/domain-4"
      },
      {
        "@id": "https://taxonomy.eticas.ai/external/nist-ai-600-1/information-security"
      },
      {
        "@id": "https://taxonomy.eticas.ai/external/nist-ai-rmf/secure-resilient"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "The risk that an AI system is exposed to AI-specific vulnerabilities, attacks, or misuse that compromise its integrity, availability, or confidentiality. This covers risks beyond traditional IT security, including adversarial inputs, prompt injection, model extraction, jailbreaking, and supply-chain risks specific to AI components. It is intended to complement, not replace, standard IT security assessments."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/security-ai-attacks"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/security-system"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/security-harmful-misuse"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Security & Misuse"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/lifecycleStage": [
      {
        "@value": "pre-processing"
      },
      {
        "@value": "in-processing"
      },
      {
        "@value": "post-processing"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/maturity": [
      {
        "@value": "established"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/perspective": [
      {
        "@value": "technical soundness"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/scope": [
      {
        "@value": "ALL"
      }
    ]
  },
