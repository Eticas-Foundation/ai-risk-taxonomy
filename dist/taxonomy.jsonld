      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "The system has not been validated against the problem it is intended to solve, or does not achieve adequate or equitable task performance across subpopulations and input types. Covers both the ex ante question (was this designed for this problem?) and the ex post question (does it actually work?)."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Fitness for purpose and task effectiveness"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/lifecycleStage": [
      {
        "@value": "pre-processing"
      },
      {
        "@value": "in-processing"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/maturity": [
      {
        "@value": "emerging"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/scope": [
      {
        "@value": "ALL"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/institutional-capacity",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/organisational-readiness"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "The broader institutional or societal context lacks foundational capabilities (digital infrastructure, data literacy, regulatory frameworks) needed before AI deployment is viable. Premature deployment may reallocate scarce resources, exacerbate inequality, or create technological dependency."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Institutional absorptive capacity"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/lifecycleStage": [
      {
        "@value": "pre-processing"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/maturity": [
      {
        "@value": "emerging"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/scope": [
      {
        "@value": "ALL"
      }
    ]
  },
  {
    "@id": "https://w3id.org/dpv/legal/eu/aiact#article-5",
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Article 5 — Prohibited AI practices (emotion recognition, biometric categorization)"
      }
    ]
  },
  {
    "@id": "https://airisk.mit.edu/domain/subdomain-6.6",
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Environmental harm"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/deployment-sustainability",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/organisational-readiness"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "The organisation lacks the capacity for ongoing operation, maintenance, monitoring, and improvement of the AI system after initial deployment. Includes vendor lock-in risk, dependency on external expertise, and unclear cost-effectiveness or value proposition."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Deployment sustainability"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/lifecycleStage": [
      {
        "@value": "post-processing"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/maturity": [
      {
        "@value": "emerging"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/scope": [
      {
        "@value": "ALL"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/external/nist-ai-rmf/map",
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "MAP function — context and deployment environment"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/graceful-degradation",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/reliability-resilience"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Absence of defined degradation pathways that allow the system to maintain partial function when components fail, connectivity is lost, or resources are constrained."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Graceful degradation"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/lifecycleStage": [
      {
        "@value": "post-processing"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/maturity": [
      {
        "@value": "emerging"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/scope": [
      {
        "@value": "ALL"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/external/iso-42001/A.7",
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Data management"
      }
    ]
  },
  {
    "@id": "https://w3id.org/dpv/ai#PromptInjection",
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Prompt Injection"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/privacy-confidentiality",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@language": "en",
        "@value": "Privacy"
      },
      {
        "@language": "en",
        "@value": "Data Privacy"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broadMatch": [
      {
        "@id": "https://taxonomy.eticas.ai/external/oecd-ai/principle-1.2"
      },
      {
        "@id": "https://w3id.org/dpv/ai#PersonalDataHandling"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "https://airisk.mit.edu/domain/subdomain-2.1"
      },
      {
        "@id": "https://taxonomy.eticas.ai/external/nist-ai-600-1/data-privacy"
      },
      {
        "@id": "https://taxonomy.eticas.ai/external/nist-ai-rmf/privacy-enhanced"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "The risk that an AI system collects, processes, or infers personal information in ways that infringe on individuals' rights to control their data (privacy), or that sensitive information is exposed, accessed, or shared without authorization (confidentiality). This includes risks from data leakage, re-identification, unauthorized use, or insufficient safeguards."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/privacy-collection-use"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/privacy-data-protection"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/privacy-model-level"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Privacy & Confidentiality"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/lifecycleStage": [
      {
        "@value": "pre-processing"
      },
      {
        "@value": "in-processing"
      },
      {
        "@value": "post-processing"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/maturity": [
      {
        "@value": "established"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/perspective": [
      {
        "@value": "rights & ethics"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/scope": [
      {
        "@value": "ALL"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/org-preparedness",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/organisational-readiness"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "The deploying organisation lacks the governance maturity, leadership engagement, change management capacity, staff competency, or cultural receptivity needed to absorb an AI system into its operations."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Organisational preparedness"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/lifecycleStage": [
      {
        "@value": "pre-processing"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/maturity": [
      {
        "@value": "emerging"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/scope": [
      {
        "@value": "ALL"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/transparency-communication",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/transparency-explainability"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "https://w3id.org/dpv/legal/eu/aiact#article-13"
      },
      {
        "@id": "https://taxonomy.eticas.ai/external/oecd-ai/principle-1.3"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Risks from inadequate communication about system capabilities, limitations, and AI involvement."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/stakeholder-communication"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/ai-interaction-disclosure"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Communication & disclosure"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/security-harmful-misuse",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
