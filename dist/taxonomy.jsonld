[
  {
    "@id": "https://taxonomy.eticas.ai/risk/organisational-readiness",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@language": "en",
        "@value": "Integration Readiness"
      },
      {
        "@language": "en",
        "@value": "Deployment Readiness"
      },
      {
        "@language": "en",
        "@value": "Sociotechnical Fit"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "The risk that an AI system fails to deliver value not because of model performance issues but because it does not fit the organisational, technical, or human context into which it is deployed. This includes insufficient organisational capacity to absorb the technology, workflow incompatibility, interoperability failures with existing systems, and lack of sustainable maintenance capability."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/org-preparedness"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/technical-interoperability"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/workflow-compatibility"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/deployment-sustainability"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/institutional-capacity"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Organisational Readiness"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#relatedMatch": [
      {
        "@id": "https://taxonomy.eticas.ai/external/nist-ai-rmf/map"
      },
      {
        "@id": "https://taxonomy.eticas.ai/external/iso-42001/A.10"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/lifecycleStage": [
      {
        "@value": "pre-processing"
      },
      {
        "@value": "post-processing"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/maturity": [
      {
        "@value": "emerging"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/perspective": [
      {
        "@value": "operational viability"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/scope": [
      {
        "@value": "ALL"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/bias-representational-harm",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/bias-fairness"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Risks related to how the system represents groups in its outputs — through stereotypes, toxic content, skewed representation, or homogenization. These are harms in the form of meaning and content rather than allocation of resources or opportunities."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/geographic-cultural-language-skew"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/stereotyping-demeaning-content"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/harmful-content-toxicity"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/sentiment-fairness"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/homogenization-output-across-groups"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Representational harm"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/multi-step-actions",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/autonomy-system-autonomy"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "AI systems that plan and execute sequences of actions, where errors in early steps cascade unpredictably through later steps."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Multi-step autonomous actions"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/lifecycleStage": [
      {
        "@value": "post-processing"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/maturity": [
      {
        "@value": "emerging"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/scope": [
      {
        "@value": "LLM"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/disparate-impact-protected-groups",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@language": "en",
        "@value": "Disparate impact"
      },
      {
        "@language": "en",
        "@value": "Quality of service disparity"
      },
      {
        "@language": "en",
        "@value": "Allocation of opportunity"
      },
      {
        "@language": "en",
        "@value": "Intersectional unfairness"
      },
      {
        "@language": "en",
        "@value": "Accessibility barriers"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/bias-outcome-disparities"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "The system produces systematically different — typically worse — outcomes for individuals belonging to protected groups, including across multiple intersecting attributes (race, gender, age, disability, etc.). Encompasses unequal allocation of opportunity, quality of service disparities, intersectional unfairness, and accessibility barriers."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Disparate impact on protected groups"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/lifecycleStage": [
      {
        "@value": "post-processing"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/maturity": [
      {
        "@value": "established"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/scope": [
      {
        "@value": "ALL"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/external/nist-ai-rmf/valid-reliable",
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Valid & Reliable"
      }
    ]
  },
