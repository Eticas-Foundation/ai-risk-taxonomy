  {
    "@id": "https://taxonomy.eticas.ai/external/oecd-ai/principle-1.4",
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Robustness, security & safety"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/external/nist-ai-600-1/4",
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Data Privacy"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/data-poisoning",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@language": "en",
        "@value": "Training data poisoning"
      },
      {
        "@language": "en",
        "@value": "Backdoor attacks"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/security-ai-attacks"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Adversarial manipulation of training or fine-tuning data to introduce backdoors, bias, or systematic errors into the model. Includes both broad-spectrum poisoning (degrading overall performance) and targeted poisoning (creating exploitable triggers or specific failure modes)."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Data poisoning"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/lifecycleStage": [
      {
        "@value": "pre-processing"
      },
      {
        "@value": "in-processing"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/maturity": [
      {
        "@value": "established"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/scope": [
      {
        "@value": "ALL"
      }
    ]
  },
