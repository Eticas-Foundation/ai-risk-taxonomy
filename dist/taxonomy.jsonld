      {
        "@id": "https://taxonomy.eticas.ai/risk/security-system"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Risks introduced through third-party components, pre-trained models, data sources, or other dependencies not fully under the deployer's control."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Supply-chain vulnerabilities"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/lifecycleStage": [
      {
        "@value": "pre-processing"
      },
      {
        "@value": "in-processing"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/maturity": [
      {
        "@value": "established"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/scope": [
      {
        "@value": "ALL"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/behavioural-manipulation",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/security-harmful-misuse"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Subliminal influence, dark patterns, or exploitation of cognitive biases to steer user behaviour without informed consent."
