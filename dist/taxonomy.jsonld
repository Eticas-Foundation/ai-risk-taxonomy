  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/governance-compliance",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#broadMatch": [
      {
        "@id": "https://taxonomy.eticas.ai/external/iso-42001/A.9.3"
      }
