      {
        "@id": "https://taxonomy.eticas.ai/risk/unlawful-data-processing"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/function-creep"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/biometric-surveillance"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/emotion-inference-profiling"
      }
    ],
