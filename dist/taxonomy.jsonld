        "@id": "https://taxonomy.eticas.ai/risk/monitoring-evaluation-gaps"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/regulatory-non-compliance"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/lack-of-change-management"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/fitness-for-purpose"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/data-governance"
