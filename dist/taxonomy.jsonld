  {
    "@id": "https://taxonomy.eticas.ai/risk/manipulation-misinformation",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "https://airisk.mit.edu/domain/domain-3"
      },
      {
        "@id": "https://taxonomy.eticas.ai/external/nist-ai-600-1/information-integrity"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "The risk that AI systems are used — intentionally or through design flaws — to deceive, manipulate, or mislead individuals or populations. This includes generation of disinformation at scale, deepfakes, subliminal manipulation, and pollution of the information ecosystem."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
