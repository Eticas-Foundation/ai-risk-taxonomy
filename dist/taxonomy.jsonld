      {
        "@id": "https://taxonomy.eticas.ai/risk/security-misuse"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Risks from deliberate misuse of the AI system to generate harmful content, manipulate users, or operate beyond its intended purpose. These risks involve human intent — distinguishing them from unintentional system failures (which belong under Reliability)."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/behavioural-manipulation"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/synthetic-media-abuse"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/misuse-beyond-intended-purpose"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Harmful Misuse"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/incident-response-gaps",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
