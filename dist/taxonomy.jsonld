      {
        "@language": "en",
        "@value": "Data Privacy"
      }
    ]
  },
  {
    "@id": "https://airisk.mit.edu/domain/subdomain-1.1",
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Unfair discrimination & misrepresentation"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/unlawful-data-processing",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/privacy-collection-use"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Collection, storage, or processing of personal data without adequate legal basis, consent, or compliance with applicable data protection regulations."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Unlawful collection or processing of personal data"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/lifecycleStage": [
      {
        "@value": "pre-processing"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/maturity": [
      {
        "@value": "established"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/scope": [
      {
        "@value": "ALL"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/edge-offline-operability",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
