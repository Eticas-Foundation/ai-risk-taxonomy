        "@id": "https://taxonomy.eticas.ai/risk/governance-accountability"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Lack of defined intervention points, override capabilities, or human review mechanisms, allowing issues and threats to persist unchecked."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Human oversight and control"
      }
    ],
