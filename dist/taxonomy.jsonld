      {
        "@id": "https://taxonomy.eticas.ai/risk/reliability-resilience"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "System inability to function without continuous cloud access or network connectivity, creating single points of failure in environments with unreliable infrastructure."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Edge and offline operability"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/lifecycleStage": [
      {
        "@value": "post-processing"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/maturity": [
      {
        "@value": "emerging"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/scope": [
      {
        "@value": "ALL"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/security-system",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/security-misuse"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "https://taxonomy.eticas.ai/external/nist-ai-600-1/9"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Risks related to access control and integrity of the AI system and its supply chain."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/unauthorized-access"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/supply-chain-vulnerabilities"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "System security"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#relatedMatch": [
      {
        "@id": "https://taxonomy.eticas.ai/external/iso-42001/A.6.2.3"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/autonomy-system-autonomy",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/autonomy-agency"
      }
    ],
