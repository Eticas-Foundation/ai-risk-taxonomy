      }
    ],
    "https://taxonomy.eticas.ai/ontology/lifecycleStage": [
      {
        "@value": "pre-processing"
      },
      {
        "@value": "post-processing"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/maturity": [
      {
        "@value": "emerging"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/scope": [
      {
        "@value": "ALL"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/bias-fairness",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@language": "en",
        "@value": "Fairness"
      },
      {
        "@language": "en",
        "@value": "Bias & Discrimination"
      },
      {
        "@language": "en",
        "@value": "Algorithmic fairness"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broadMatch": [
      {
        "@id": "https://taxonomy.eticas.ai/external/oecd-ai/principle-1.2"
      },
      {
        "@id": "https://w3id.org/dpv/ai#AIBias"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "https://airisk.mit.edu/domain/domain-1"
      },
      {
        "@id": "https://taxonomy.eticas.ai/external/nist-ai-600-1/harmful-bias"
      },
      {
        "@id": "https://taxonomy.eticas.ai/external/nist-ai-rmf/fair"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "The risk that an AI system produces outcomes that systematically advantage or disadvantage individuals or groups based on protected or sensitive attributes, leading to unequal treatment, reduced accuracy, or unjust impacts. This includes biases introduced through data, model design, or deployment context, and covers both measurable disparities and perceived unfairness in decision-making."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/bias-outcome-disparities"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/bias-representational-harm"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/bias-dynamic-systemic-bias"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Bias & Fairness"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#relatedMatch": [
      {
        "@id": "https://taxonomy.eticas.ai/external/iso-42001/A.8"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/lifecycleStage": [
      {
        "@value": "pre-processing"
      },
      {
        "@value": "in-processing"
      },
      {
        "@value": "post-processing"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/maturity": [
      {
        "@value": "established"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/perspective": [
      {
        "@value": "rights & ethics"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/scope": [
      {
        "@value": "ALL"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/automation-bias",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/autonomy-human-agency"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Over-reliance on automated outputs, accepting AI recommendations without sufficient scrutiny, leading to missed errors and reduced human judgment."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Automation bias"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/lifecycleStage": [
      {
        "@value": "post-processing"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/maturity": [
      {
        "@value": "emerging"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/scope": [
      {
        "@value": "ALL"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/stakeholder-communication",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/source": [
      {
        "@value": "HRA"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@language": "en",
        "@value": "Communication to relevant interested parties"
      },
      {
        "@language": "en",
        "@value": "Communication to stakeholders"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/transparency-communication"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "The AI system's capabilities, limitations, intended use cases, and known failure modes are not communicated clearly to deployers, users, or affected parties, leading to misuse, over-reliance, or under-reliance on the system."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Inadequate disclosure of system capabilities and limitations"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/lifecycleStage": [
      {
        "@value": "post-processing"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/maturity": [
      {
        "@value": "emerging"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/scope": [
      {
        "@value": "ALL"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/deskilling",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
