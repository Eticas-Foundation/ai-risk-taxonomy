  },
  {
    "@id": "https://taxonomy.eticas.ai/external/nist-ai-600-1/environmental",
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Environmental Impacts"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/performance-equity",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/source": [
      {
        "@value": "HRA"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@language": "en",
        "@value": "Group-wise error rate"
      },
      {
        "@language": "en",
        "@value": "Performance equity across populations"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/bias-outcome-disparities"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "https://airisk.mit.edu/domain/subdomain-1.3"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "The AI system performs systematically worse for some demographic groups than others — through higher error rates, lower accuracy, or reduced reliability — leading to unequal quality of service even when access is the same."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Differential performance across populations"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/lifecycleStage": [
      {
        "@value": "in-processing"
      },
      {
        "@value": "post-processing"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/maturity": [
      {
        "@value": "emerging"
      }
    ],
    "https://taxonomy.eticas.ai/ontology/scope": [
      {
        "@value": "ALL"
      }
    ]
  },
  {
    "@id": "https://taxonomy.eticas.ai/risk/transparency-explainability",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@language": "en",
        "@value": "Explainability & Transparency"
      },
      {
        "@language": "en",
        "@value": "Transparency and Explainability"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broadMatch": [
      {
        "@id": "https://w3id.org/dpv/ai#Transparency"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "https://airisk.mit.edu/domain/subdomain-7.4"
      },
      {
        "@id": "https://taxonomy.eticas.ai/external/nist-ai-rmf/explainable-interpretable"
      },
      {
        "@id": "https://taxonomy.eticas.ai/external/oecd-ai/principle-1.3"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "The risk that stakeholders cannot understand how an AI system works, what it does, or why it produces specific outputs. Lack of transparency undermines informed consent, impedes oversight, and erodes trust."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/transparency-explainability-group"
      },
      {
        "@id": "https://taxonomy.eticas.ai/risk/transparency-communication"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#note": [
      {
        "@language": "en",
        "@value": "In the RAIA Guide, this category is assessed only at the Post-Processing stage."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Transparency & Explainability"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
