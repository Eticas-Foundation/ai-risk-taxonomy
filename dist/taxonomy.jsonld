  {
    "@id": "https://taxonomy.eticas.ai/risk/autonomy-agency",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@language": "en",
        "@value": "Autonomy & Human Agency"
      },
      {
        "@language": "en",
        "@value": "Agentic Risks"
      },
      {
        "@language": "en",
        "@value": "Human-AI Interaction"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broadMatch": [
      {
        "@id": "https://w3id.org/dpv/ai#HumanOversight"
      },
      {
        "@id": "https://w3id.org/dpv/legal/eu/aiact#article-14"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "https://airisk.mit.edu/domain/domain-5"
      },
      {
        "@id": "https://taxonomy.eticas.ai/external/nist-ai-600-1/7"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "The risk that an AI system undermines human agency or operates with insufficient human control. This includes over-reliance on AI outputs, automation bias, deskilling, and — for agentic AI systems — failure modes arising from multi-step autonomous actions, tool use, or coordination with other AI agents."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://taxonomy.eticas.ai/risk/scheme"
      }
    ],
